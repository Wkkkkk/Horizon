{
  "version": "1.0",
  "ai": {
    "provider": "anthropic",
    "model": "claude-haiku-4-5-20251001",
    "api_key_env": "ANTHROPIC_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0,
    "languages": [
      "en"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "Semianalysis",
        "url": "https://newsletter.semianalysis.com/feed",
        "enabled": true,
        "category": "semiconductors"
      },
      {
        "name": "The Batch (deeplearning.ai)",
        "url": "https://www.deeplearning.ai/the-batch/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "webrtcHacks",
        "url": "https://webrtchacks.com/feed/",
        "enabled": true,
        "category": "media-streaming"
      },
      {
        "name": "Mux Blog",
        "url": "https://www.mux.com/blog/rss.xml",
        "enabled": true,
        "category": "media-streaming"
      },
      {
        "name": "Cloudflare Stream",
        "url": "https://blog.cloudflare.com/tag/stream/rss/",
        "enabled": true,
        "category": "media-streaming"
      },
      {
        "name": "OTTVerse",
        "url": "https://ottverse.com/feed/",
        "enabled": true,
        "category": "media-streaming"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "programming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 200
        },
        {
          "subreddit": "ClaudeCode",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 25
        },
        {
          "subreddit": "vibecoding",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 25
        },
        {
          "subreddit": "Anthropic",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 25
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "github": [
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "video-dev",
        "repo": "hls.js",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "shaka-project",
        "repo": "shaka-player",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "gpac",
        "repo": "gpac",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "Eyevinn",
        "repo": "mp4ff",
        "enabled": true
      }
    ]
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 24,
    "max_items": 24,
    "category_groups": {
      "media": {
        "name": "Streaming / Media",
        "limit": 5,
        "categories": ["media-streaming"]
      },
      "ai": {
        "name": "AI / ML",
        "limit": 6,
        "categories": ["ai-news", "ai-tools", "machine-learning", "semiconductors"]
      }
    },
    "default_group": "general",
    "default_group_limit": 12
  },
  "webhook": {
    "enabled": false
  }
}
